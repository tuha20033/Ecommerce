@using Application.DTOs
@using Application.Features.Customer.Commands.CreateCustomer
@using Application.Features.Customer.Commands.UpdateCustomerCommandandHandler
@using Application.Features.Customer.Queries.GetCustomerById
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
            @((Id == Guid.Empty) ? "Thêm khách hàng" : "Sửa khách hàng")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">
            <MudTextField Label="Họ và tên" @bind-Value="customer.FullName" Required="true" />
            <MudTextField Label="Email" @bind-Value="customer.Email" Required="true" Class="mt-2" />
            <MudTextField Label="Số điện thoại" @bind-Value="customer.Phone" Class="mt-2" />
            <MudDatePicker Label="Ngày sinh" @bind-Date="dateOfBirth" Class="mt-2" />
            <MudTextField Label="Ảnh đại diện (URL)" @bind-Value="customer.AvatarUrl" Class="mt-2" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public Guid Id { get; set; }

    private MudForm form;
    private bool isValid;
    private CustomerDTO customer = new();
    private DateTime? dateOfBirth;

    protected override async Task OnInitializedAsync()
    {
        if (Id != Guid.Empty)
        {
            var result = await Mediator.Send(new GetCustomerByIdQuery { Id = Id });
            if (result != null)
            {
                customer = result;
                dateOfBirth = customer.DateOfBirth;
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        await form.Validate();
        if (!isValid) return;

        customer.DateOfBirth = dateOfBirth;

        try
        {
            if (Id == Guid.Empty)
            {
                var command = new CreateCustomerCommand
                {
                    FullName = customer.FullName,
                    Email = customer.Email,
                    Phone = customer.Phone,
                    DateOfBirth = customer.DateOfBirth,
                    AvatarUrl = customer.AvatarUrl
                };
                await Mediator.Send(command);
                Snackbar.Add("Thêm khách hàng thành công", Severity.Success);
            }
            else
            {
                var command = new UpdateCustomerCommand
                {
                    Id = Id,
                    FullName = customer.FullName,
                    Email = customer.Email,
                    Phone = customer.Phone,
                    DateOfBirth = customer.DateOfBirth,
                    AvatarUrl = customer.AvatarUrl
                };
                await Mediator.Send(command);
                Snackbar.Add("Cập nhật khách hàng thành công", Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}