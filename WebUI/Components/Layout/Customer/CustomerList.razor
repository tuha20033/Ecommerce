@page "/customer"
@using Application.DTOs
@using Application.Features.Customer.Queries.GetAllCustomers
@using MediatR
@inject IMediator Mediator
@inject IDialogService _dialogService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudTable Items="@customers" Dense="true" Hover="true" Bordered="true" Striped="true" Filter="FilterFunc">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách khách hàng</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Tìm kiếm" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mt-0" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Họ tên</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Số điện thoại</MudTh>
        <MudTh>Ngày sinh</MudTh>
        <MudTh>Ngày tạo</MudTh>
        <MudTh>Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Họ tên">@context.FullName</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Số điện thoại">@context.Phone</MudTd>
        <MudTd DataLabel="Ngày sinh">@context.DateOfBirth?.ToString("dd/MM/yyyy")</MudTd>
        <MudTd DataLabel="Ngày tạo">@context.CreateAt.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenDialog(context.Id))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => Delete(context.Id))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<CustomerDTO> customers = new();
    private string searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        customers = await Mediator.Send(new GetAllCustomersQuery());
    }

    private bool FilterFunc(CustomerDTO customer)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        return customer.FullName.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || customer.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || (customer.Phone?.Contains(searchString) ?? false);
    }

    private async Task OpenDialog(Guid id)
    {
        var parameters = new DialogParameters { ["Id"] = id };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await _dialogService.ShowAsync<CustomerEdit>(id == Guid.Empty ? "Thêm khách hàng" : "Sửa khách hàng", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task Delete(Guid id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa khách hàng này không?");
        if (confirm)
        {
            // TODO: Implement DeleteCustomerCommand
            Snackbar.Add("Chức năng xóa khách hàng sẽ sớm ra mắt", Severity.Info);
        }
    }
}