@page "/"
@using Application.DTOs
@using Application.Features.Cart.Commands.CreatCartCommamdHandler
@using Application.Features.Product.Queries.GetAllProducts
@using MediatR
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        @foreach (var item in products)
        {
            var _item = item;
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Style="max-height:230px; max-with:120px">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudAvatar Color="Color.Secondary">I</MudAvatar>
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.body1">@_item.Name</MudText>
                            <MudText Typo="Typo.body2">Còn: @_item.WareHouse</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudFabMenu StartIcon="@Icons.Material.Outlined.Settings"
                                        Color="Color.Primary"
                                        Direction="@_direction"
                                        Size="Size.Small">
                                <MudFabMenuItem EndIcon="@Icons.Material.Outlined.LooksOne" Color="Color.Primary" Size="Size.Small" />
                                <MudFabMenuItem EndIcon="@Icons.Material.Outlined.LooksTwo" Color="Color.Primary" Size="Size.Small" />
                                <MudFabMenuItem EndIcon="@Icons.Material.Outlined.Looks3" Color="Color.Primary" Size="Size.Small" />
                            </MudFabMenu>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardMedia Image="@_item.ImageUrl" Height="200" />
                    <MudCardContent>
                        <MudText>@_item.Description</MudText>
                        <MudText>@_item.Price.ToString("N0") đ</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                       Color="Color.Primary"
                                       Title="Thêm vào giỏ hàng"
                                       OnClick="@(() => AddToCart(_item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ShoppingCartCheckout"
                                       Color="Color.Success"
                                       Title="Đặt hàng"
                                       OnClick="@(() => PlaceOrder(_item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.RateReview"
                                       Color="Color.Warning"
                                       Title="Đánh giá"
                                       OnClick="@(() => WriteReview(_item))" />
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private Direction _direction = Direction.Right;
    private List<ProductDTO> products = new();
    private Guid currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst("sub");
        if (idClaim is not null)
            Guid.TryParse(idClaim.Value, out currentUserId);

        await LoadData();
    }

    private async Task LoadData()
    {
        products = await Mediator.Send(new GetAllProductsQuery());
        StateHasChanged();
    }

    private async Task AddToCart(ProductDTO item)
    {
        var customer = await Mediator.Send(new GetCustomerByUserIdQuery(currentUserId)
  );

        if (customer == null)
        {
            Snackbar.Add("Tài khoản này chưa có Customer", Severity.Error);
            return;
        }

        var command = new CreateCartCommand
        {
            CustomerId = currentUserId,
            ProductId = item.Id,
            UnitPrice = item.Price,
            Quantity = 1
        };
        await Mediator.Send(command);
        Snackbar.Add($"Đã thêm \"{item.Name}\" vào giỏ hàng", Severity.Success);
    }

    private void PlaceOrder(ProductDTO item)
    {
        Navigation.NavigateTo("/cart");
    }

    private async Task WriteReview(ProductDTO item)
    {
        Snackbar.Add($"Chức năng đánh giá \"{item.Name}\" đang phát triển", Severity.Info);
    }
}