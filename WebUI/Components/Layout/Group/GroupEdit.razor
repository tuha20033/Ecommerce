@using Application.DTOs
@using Application.Features.Group.Commands.CreateGroupCommandsandHandler
@using Application.Features.Group.Commands.UpdateGroupCommandandHandler
@using Application.Features.Group.Queries.GetByIds
@using Application.Features.Warehouse.Commands.CreateWarehouseCommandandHandler
@using Application.Features.Warehouse.Commands.UpdateWarehouseCommandandHandler
@using Application.Features.Warehouse.Queries.GetByIdWarehouses
@using MediatR
@inject IMediator _mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Warehouse" />
            @((Id == Guid.Empty) ? "Thêm nhóm" : "Chỉnh sửa nhóm")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">
            <MudTextField Label="Tên kho"
                          @bind-Value="group.name"
                          Required="true" />
            <MudTextField Label="Địa chỉ"
                          @bind-Value="group.description"
                          Class="mt-2" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Save"
                       Class="mt-3">
                Lưu
            </MudButton>
        </MudForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public Guid Id { get; set; }

    private MudForm form;
    private bool isValid;
    private GroupDTO group = new();
    protected override async Task OnInitializedAsync()
    {
        if (Id != Guid.Empty)
        {
            var query = new GetByIdQuery { Id = Id };
            group = await _mediator.Send(query);
        }
    }
    private async Task Save()
    {
        await form.Validate();
        if (!isValid) return;

        try
        {
            if (Id != Guid.Empty)
            {
                var updateCommand = new UpdateGroupCommand
                {
                    Id = Id,
                    Name = group.name,
                    Description = group.description,
                   
                };
                await _mediator.Send(updateCommand);
                Snackbar.Add("Cập nhật kho thành công!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
                return;
            }
            else
            {
                var command = new CreateGroupCommands
                {
                    Name = group.name,
                    Description = group.description,
                };
                await _mediator.Send(command);
                Snackbar.Add("Lưu kho thành công!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }

        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}