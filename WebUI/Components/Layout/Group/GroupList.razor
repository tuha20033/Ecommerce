@page "/group"
@using Application.DTOs
@using Application.Features.Group.Queries.GetAllGroups
@using Application.Features.Warehouse.Queries.GetAllWarehouse
@using MediatR
@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar


<MudTable Items="@group" Dense="@dense" Hover="true" Bordered="false"
          Striped="true" Filter="FilterFunc">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách kho</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="@(() => OpenDialog(Guid.Empty))">
            Thêm Nhóm
        </MudButton>
        <MudTextField @bind-Value="searchString"
                      Placeholder="Tìm kiếm..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="mt-0 ml-2" />
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Tên Nhóm</MudTh>
        <MudTh>Mô Tả</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Action</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.name</MudTd>
        <MudTd>@context.description</MudTd>
        <MudTd>@context.parentId</MudTd>
       
        <MudTd>
            <MudButton Color="Color.Primary"
                       OnClick="@(() => OpenDialog(context.Id))">
                Edit
            </MudButton>
            <MudButton Color="Color.Error"
                       OnClick="@(() => Delete(context.Id))"
                       Class="ml-2">
                Delete
            </MudButton>
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<GroupDTO> group = new();
    private string searchString = "";
    private bool dense = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        group = await Mediator.Send(new GetAllGroupQuery());
    }

    private bool FilterFunc(GroupDTO w)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return w.name.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || (w.description?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);

    }

    private async Task OpenDialog(Guid id)
    {
        var parameters = new DialogParameters { ["Id"] = id };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<GroupEdit>("Nhóm", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task Delete(Guid id)
    {
        // Thêm DeleteWarehouseCommand sau
        Snackbar.Add("Chức năng đang phát triển", Severity.Info);
    }
}