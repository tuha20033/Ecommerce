@using Application.DTOs
@using Application.Features.Group.Queries.GetAllGroups
@using Application.Features.Product.Commands.CreateProductCommandandHandler
@using Application.Features.Product.Commands.UpdateProduct
@using Application.Features.Product.Commands.UpdateProductCommandandHandler
@using Application.Features.Product.Queries.GetProductById
@using Application.Features.Warehouse.Queries.GetAllWarehouse
@using MediatR
@using System.Threading.Tasks
@inject ISnackbar Snackbar
@inject IMediator _mediator
@using MudBlazor
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" />
            @((Id == Guid.Empty) ? "Thêm mới" : "Chỉnh sửa")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">

            <MudTextField Label="Tên sản phẩm"
                          @bind-Value="product.Name"
                          Required="true" />

            <MudTextField Label="Mã sản phẩm"
                          @bind-Value="product.ProductCode"
                          Required="true" />

            <MudTextField Label="Mô tả"
                          @bind-Value="product.Description" />

            <MudTextField Label="Giá"
                          @bind-Value="product.Price"
                          Required="true" />
                      
            <MudTextField Label="Tồn kho"
                          @bind-Value="product.WareHouse"
                          Required="true" />

            <MudTextField Label="Image Url"
                          @bind-Value="product.ImageUrl" />

         
            <MudSelect T="Guid"
                       Label="Kho"
                       @bind-Value="product.WarehouseId"
                       Required="true"
                       AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem T="Guid" Value="Guid.Empty" Disabled="true">-- Chọn kho --</MudSelectItem>
                @foreach (var warehouse in WareHouse)
                {
                    <MudSelectItem T="Guid" Value="@warehouse.Id">@warehouse.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="Guid"
                       Label="Nhóm"
                       @bind-Value="product.GroupId"
                       Required="true"
                       AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem T="Guid" Value="Guid.Empty" Disabled="true">-- Chọn nhóm --</MudSelectItem>
                @foreach (var group in groups)
                {
                    <MudSelectItem T="Guid" Value="@group.Id">@group.name</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveProduct"
                       Class="mt-3">
                Lưu
            </MudButton>

        </MudForm>
    </DialogContent>
</MudDialog>
@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public Guid Id { get; set; }

    private ProductDTO product = new ProductDTO();
    private List<WarehouseDTO> WareHouse = new ();
    private List<GroupDTO> groups = new ();
    private MudForm form;
    private bool isValid;
    protected override async Task OnInitializedAsync()
    {
        var warehouseQuery = new GetAllWarehouseQuery();
        WareHouse = await _mediator.Send(warehouseQuery);

        var groupquery = new GetAllGroupQuery();
        groups = await _mediator.Send(groupquery);
        if (Id != Guid.Empty)
        {
            var query = new GetProductByIdQuery() { Id = Id };
            product = await _mediator.Send(query);
            StateHasChanged();
        }
    }
    private async Task SaveProduct()
    {
        await form.Validate();
        if (product.GroupId == Guid.Empty)
        {
            Snackbar.Add("Vui lòng chọn nhóm", Severity.Warning);
            return;
        }
        if (product.WarehouseId == Guid.Empty)
        {
            Snackbar.Add("Vui lòng chọn kho", Severity.Warning);
            return;
        }
        if (isValid)
        {
            try {
                if (Id != Guid.Empty)
                {
                    var command = new UpdateProductCommand()
                        {
                            Id = Id,
                            Name = product.Name,
                            ProductCode = product.ProductCode,
                            Description = product.Description,
                            Price = product.Price,
                            ImageUrl = product.ImageUrl,
                            WareHouse = product.WareHouse,
                            WarehouseId = product.WarehouseId,
                            GroupId = product.GroupId,

                        };
                    await _mediator.Send(command);
                }
                else
                {
                    var command = new CreateProductCommands()
                        {
                            Name = product.Name,
                            ProductCode = product.ProductCode,
                            Description = product.Description,
                            Price = product.Price,
                            ImageUrl = product.ImageUrl,
                            WareHouse = product.WareHouse,
                            GroupId = product.GroupId,
                            WarehouseId = product.WarehouseId
                        };
                    await _mediator.Send(command);
                }
                Snackbar.Add("Lưu thành công!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
       
    }

}