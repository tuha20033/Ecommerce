@page "/warehouse"
@using Application.DTOs
@using Application.Features.Warehouse.Queries.GetAllWarehouse
@using MediatR
@inject IMediator Mediator
@inject IDialogService DialogService
@inject ISnackbar Snackbar


<MudTable Items="@warehouses" Dense="@dense" Hover="true" Bordered="false"
          Striped="true" Filter="FilterFunc">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách kho</MudText>
        <MudSpacer />
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="@(() => OpenDialog(Guid.Empty))">
            Thêm kho
        </MudButton>
        <MudTextField @bind-Value="searchString"
                      Placeholder="Tìm kiếm..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Class="mt-0 ml-2" />
    </ToolBarContent>

    <HeaderContent>
        <MudTh>Tên kho</MudTh>
        <MudTh>Địa chỉ</MudTh>
        <MudTh>Số điện thoại</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Action</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.Address</MudTd>
        <MudTd>@context.Phone</MudTd>
        <MudTd>
            @if (context.IsActive)
            {
                <MudChip T="string" Color="Color.Success" Size="Size.Small">Hoạt động</MudChip>
            }
            else
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small">Ngừng</MudChip>
            }
        </MudTd>
        <MudTd>
            <MudButton Color="Color.Primary"
                       OnClick="@(() => OpenDialog(context.Id))">
                Edit
            </MudButton>
            <MudButton Color="Color.Error"
                       OnClick="@(() => Delete(context.Id))"
                       Class="ml-2">
                Delete
            </MudButton>
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<WarehouseDTO> warehouses = new();
    private string searchString = "";
    private bool dense = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        warehouses = await Mediator.Send(new GetAllWarehouseQuery());
    }

    private bool FilterFunc(WarehouseDTO w)
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        return w.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase)
            || (w.Address?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            || (w.Phone?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    private async Task OpenDialog(Guid id)
    {
        var parameters = new DialogParameters { ["Id"] = id };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<WarehouseEdit>("Kho hàng", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task Delete(Guid id)
    {
        // Thêm DeleteWarehouseCommand sau
        Snackbar.Add("Chức năng đang phát triển", Severity.Info);
    }
}