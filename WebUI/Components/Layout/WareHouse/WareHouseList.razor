@page "/warehouse"
@using Application.DTOs
@using Application.Features.Warehouse.Commands.DeleteWarehouse
@using Application.Features.Warehouse.Queries.GetAllWarehouse
@using MediatR
@inject IMediator Mediator
@inject IDialogService _dialogService
@inject ISnackbar Snackbar

<MudTable Items="@warehouses" Dense="true" Hover="true" Bordered="true" Striped="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách kho hàng</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenDialog(Guid.Empty))">Thêm kho hàng</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Tên kho</MudTh>
        <MudTh>Địa chỉ</MudTh>
        <MudTh>Số điện thoại</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tên kho">@context.Name</MudTd>
        <MudTd DataLabel="Địa chỉ">@context.Address</MudTd>
        <MudTd DataLabel="Số điện thoại">@context.Phone</MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                @(context.IsActive ? "Hoạt động" : "Ngừng")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OpenDialog(context.Id))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteWarehouse(context.Id))" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<WarehouseDTO> warehouses = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        warehouses = await Mediator.Send(new GetAllWarehouseQuery());
    }

    private async Task OpenDialog(Guid id)
    {
        var parameters = new DialogParameters { ["Id"] = id };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await _dialogService.ShowAsync<WarehouseEdit>("Kho hàng", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadData();
        }
    }

    private async Task DeleteWarehouse(Guid id)
    {
        var result = await Mediator.Send(new DeleteWarehouseCommand { Id = id });
        if (result)
        {
            Snackbar.Add("Xóa kho hàng thành công", Severity.Success);
            await LoadData();
        }
    }
}