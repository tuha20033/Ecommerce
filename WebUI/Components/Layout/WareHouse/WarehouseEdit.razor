@using Application.DTOs
@using Application.Features.Warehouse.Commands.CreateWarehouseCommandandHandler
@using MediatR
@inject IMediator _mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Warehouse" />
            @((Id == Guid.Empty) ? "Thêm kho" : "Chỉnh sửa kho")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="isValid">
            <MudTextField Label="Tên kho"
                          @bind-Value="warehouse.Name"
                          Required="true" />
            <MudTextField Label="Địa chỉ"
                          @bind-Value="warehouse.Address"
                          Class="mt-2" />
            <MudTextField Label="Số điện thoại"
                          @bind-Value="warehouse.Phone"
                          Class="mt-2" />
            <MudSwitch @bind-Value="warehouse.IsActive"
                       Color="Color.Primary"
                       Label="Đang hoạt động"
                       Class="mt-2" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Save"
                       Class="mt-3">
                Lưu
            </MudButton>
        </MudForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public Guid Id { get; set; }

    private MudForm form;
    private bool isValid;
    private WarehouseDTO warehouse = new() { IsActive = true };

    private async Task Save()
    {
        await form.Validate();
        if (!isValid) return;

        try
        {
            var command = new CreateWareHouseCommand
            {
                Name = warehouse.Name,
                Address = warehouse.Address,
                Phone = warehouse.Phone,
                IsActive = warehouse.IsActive
            };
            await _mediator.Send(command);
            Snackbar.Add("Lưu kho thành công!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}